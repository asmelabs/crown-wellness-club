{
	"name": "crown-wellness",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev:direct": "next dev",
		"build": "next build",
		"start": "next start",
		"type-check": "next typegen &&  tsc --noEmit",
		"lint": "biome check",
		"prepare": "husky",
		"format": "biome format --write",
		"predev": "bun run typegen",
		"check": "bun run type-check && bun run typegen && bun run lint && bun run format",
		"prebuild": "bun run check",
		"sanity:extract": "sanity schema extract",
		"sanity:typegen": "sanity typegen generate",
		"typegen": "bun run sanity:extract && bun run sanity:typegen",
		"next:build": "next build"
	},
	"dependencies": {
		"@base-ui/react": "^1.0.0",
		"@hookform/resolvers": "^5.2.2",
		"@mux/mux-player-react": "^3.10.2",
		"@next/third-parties": "^16.1.4",
		"@sanity/color-input": "^6.0.3",
		"@sanity/icons": "^3.7.4",
		"@sanity/image-url": "1",
		"@sanity/vision": "4",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.36.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"framer-motion": "^12.26.2",
		"groq": "^5.3.1",
		"isomorphic-dompurify": "^2.35.0",
		"lucide-react": "^0.562.0",
		"next": "16.1.5",
		"next-intl": "^4.7.0",
		"next-sanity": "^12.0.12",
		"nuqs": "^2.8.6",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-hook-form": "^7.71.1",
		"sanity": "4",
		"sanity-plugin-simpler-color-input": "^4.0.0",
		"sanity-plugin-singleton-management": "^1.0.6",
		"styled-components": "6",
		"tailwind-merge": "^3.4.0",
		"tailwindcss-corner-shape": "^1.4.6",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "1.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
			"biome check --write"
		]
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
}
